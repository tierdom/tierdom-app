{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tierdom.app/schemas/tierdom-import-v1.json",
  "title": "Tierdom Import Format v1",
  "description": "Canonical schema for Tierdom data files. Produced by the built-in JSON export and accepted by the JSON importer. External users can wrangle data from any source into this shape to import it.",
  "type": "object",
  "required": ["schemaVersion", "appVersion", "exportedAt", "data"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "Always 1 for this version of the format."
    },
    "appVersion": {
      "type": "string",
      "description": "Version string of the app that produced the file. Informational; not validated."
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the export was produced."
    },
    "data": {
      "type": "object",
      "required": ["pages", "siteSettings", "categories"],
      "additionalProperties": false,
      "properties": {
        "pages": { "type": "array", "items": { "$ref": "#/$defs/Page" } },
        "siteSettings": { "type": "array", "items": { "$ref": "#/$defs/SiteSetting" } },
        "categories": { "type": "array", "items": { "$ref": "#/$defs/Category" } }
      }
    }
  },
  "$defs": {
    "Page": {
      "type": "object",
      "required": ["slug", "title", "content", "createdAt", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SiteSetting": {
      "type": "object",
      "required": ["key", "value", "createdAt", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "value": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "PropKeyConfig": {
      "type": "object",
      "required": ["key"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "iconSet": { "type": "string" }
      }
    },
    "Prop": {
      "type": "object",
      "required": ["key", "value"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "value": { "type": "string" }
      }
    },
    "Item": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "name",
        "description",
        "score",
        "order",
        "imageHash",
        "placeholder",
        "props",
        "createdAt",
        "updatedAt"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Stable UUID. Used to detect duplicates between import file and existing data."
        },
        "slug": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "score": { "type": "number" },
        "order": { "type": "integer" },
        "imageHash": {
          "type": ["string", "null"],
          "description": "Image hash from the export bundle. Imports without the matching image blob will leave this null."
        },
        "placeholder": { "type": ["string", "null"] },
        "props": { "type": "array", "items": { "$ref": "#/$defs/Prop" }, "maxItems": 10 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "name",
        "description",
        "order",
        "cutoffS",
        "cutoffA",
        "cutoffB",
        "cutoffC",
        "cutoffD",
        "cutoffE",
        "cutoffF",
        "propKeys",
        "createdAt",
        "updatedAt",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "slug": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "order": { "type": "integer" },
        "cutoffS": { "type": ["number", "null"] },
        "cutoffA": { "type": ["number", "null"] },
        "cutoffB": { "type": ["number", "null"] },
        "cutoffC": { "type": ["number", "null"] },
        "cutoffD": { "type": ["number", "null"] },
        "cutoffE": { "type": ["number", "null"] },
        "cutoffF": { "type": ["number", "null"] },
        "propKeys": { "type": "array", "items": { "$ref": "#/$defs/PropKeyConfig" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/Item" } }
      }
    }
  }
}
