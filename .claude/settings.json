{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(npm run test:e2e:deterministic 2>&1)",
      "Bash(npm run test:e2e:reset 2>&1)",
      "Bash(npm run test:e2e:smoke 2>&1)",
      "Bash(npm run format 2>&1)",
      "Bash(npm run format 2>&1 && npm run lint 2>&1)",
      "Bash(npm run lint 2>&1)",
      "mcp__svelte__get-documentation",
      "mcp__svelte__list-sections",
      "mcp__svelte__svelte-autofixer",
      "Skill(adr)",
      "Skill(commit)",
      "Skill(drizzle)",
      "Skill(lint)",
      "Skill(test)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:svelte.dev)"
    ]
  }
}
