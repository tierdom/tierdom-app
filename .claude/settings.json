{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(npm run check 2>&1)",
      "Bash(npm run check 2>&1 | tail -1)",
      "Bash(npm run check 2>&1 | tail -3)",
      "Bash(npm run check 2>&1 | tail -5)",
      "Bash(npm run check 2>&1 | tail -10)",
      "Bash(npm run check 2>&1 | tail -20)",
      "Bash(npm run check 2>&1 | tail -5 && npm run test:unit 2>&1 | tail -5)",
      "Bash(npm run format 2>&1)",
      "Bash(npm run format 2>&1 && npm run lint 2>&1)",
      "Bash(npm run lint 2>&1)",
      "Bash(npm run test:e2e:deterministic 2>&1)",
      "Bash(npm run test:e2e:reset 2>&1)",
      "Bash(npm run test:e2e:smoke 2>&1)",
      "Bash(npm run test:e2e:smoke 2>&1 | tail -15)",
      "Bash(npm run test:unit -- --run 2>&1)",
      "Bash(npx playwright test --project=det-setup --project=deterministic 2>&1)",
      "Bash(npx playwright test --project=smoke 2>&1)",
      "Bash(npx svelte-check --threshold error 2>&1 | tail -5)",
      "Bash(npx svelte-check --tsconfig ./tsconfig.json 2>&1 | tail -3)",
      "Bash(npx svelte-check --tsconfig ./tsconfig.json 2>&1 | tail -5)",
      "Bash(npx svelte-check --tsconfig ./tsconfig.json 2>&1 | tail -10)",
      "mcp__svelte__get-documentation",
      "mcp__svelte__list-sections",
      "mcp__svelte__svelte-autofixer",
      "Skill(adr)",
      "Skill(commit)",
      "Skill(drizzle)",
      "Skill(lint)",
      "Skill(test)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:svelte.dev)"
    ]
  }
}
