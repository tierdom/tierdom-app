{
  "name": "tierdom-pro",
  "private": true,
  "version": "0.1.0-alpha.6",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && husky",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "verify": "npm run lint && npm run check && npm run test:unit -- --run && npm run test:unit:coverage",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest --run --coverage",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:deterministic": "playwright test --project=det-setup --project=deterministic",
    "test:e2e:reset": "mkdir -p ./test-data && rm -f ./test-data/db.sqlite ./test-data/db.sqlite-shm ./test-data/db.sqlite-wal && DATA_PATH=./test-data npx drizzle-kit migrate && tsx --env-file=.env.test src/lib/server/db/seed.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env src/lib/server/db/seed.ts",
    "db:reset": "./scripts/db-reset.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@eslint/compat": "2.0.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@sveltejs/adapter-node": "5.5.2",
    "@sveltejs/kit": "2.50.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.1.18",
    "@types/better-sqlite3": "7.6.13",
    "@types/dompurify": "3.0.5",
    "@types/node": "24",
    "@vitest/coverage-v8": "4.1.0",
    "drizzle-kit": "0.31.8",
    "drizzle-orm": "0.45.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.15.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.4.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "svelte": "5.54.0",
    "svelte-check": "4.4.2",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "7.3.1",
    "vitest": "4.1.0"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "12.6.2",
    "fflate": "0.8.2",
    "isomorphic-dompurify": "3.7.1",
    "lucide-svelte": "1.0.1",
    "marked": "17.0.5",
    "sharp": "0.34.5"
  }
}
