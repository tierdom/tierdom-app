{
	"mcpServers": {
		"svelte": {
			"type": "stdio",
			"command": "npx",
			"env": {},
			"args": ["-y", "@sveltejs/mcp"]
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@playwright/mcp@latest"]
		},
		"sqlite": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-sqlite", "./data/local.db"]
		}
	}
}
